# ============================================================
# PRODUCTION — Infomaniak (Node.js + MySQL privé)
# Colle ces variables dans : Infomaniak > App Node.js > Variables
# ============================================================

# Base de données Infomaniak (réseau interne — ne fonctionne que depuis Infomaniak)
DATABASE_URL=mysql://xy7gnv_amance:AmanceDB2026-@xy7gnv.myd.infomaniak.com:3306/xy7gnv_amance

# Clé secrète JWT (ne jamais changer après premier déploiement)
JWT_SECRET=jMMbq6Vh2yCNdfHqtVNQKKjDoSGrSjECfZsUR7P_92vL3SjAuR4HnSXuzeL5BFJl

# Domaine frontend (pour CORS + redirection OAuth)
ALLOWED_ORIGINS=https://amance.beonweb.cm
FRONTEND_URL=https://amance.beonweb.cm

# Environnement
NODE_ENV=production

# OAuth désactivé (login local uniquement)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=amance-prod
OAUTH_SERVER_URL=
OWNER_OPEN_ID=local-mimb-nout-gmail.com

# Forge API (fonctionnalités IA — laisser vide si non utilisé)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Analytics (laisser vide pour désactiver)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# -------------------------------------------------
# Railway API (production) - valeurs recommandées
# -------------------------------------------------
# Mets ces variables dans Railway > Service > Variables

# URL MySQL Infomaniak (exemple):
# DATABASE_URL=mysql://xy7gnv_amance:YourPassword@xy7gnv.myd.infomaniak.com:3306/xy7gnv_amance

# Domaine du site hébergé sur Infomaniak (frontend)
# ALLOWED_ORIGINS=https://amance.beonweb.cm
# FRONTEND_URL=https://amance.beonweb.cm

# URL publique API Railway (utilisée ensuite pour builder le frontend)
# Exemple: https://amance-api-production.up.railway.app
# VITE_API_URL=https://your-api.railway.app

# IMPORTANT:
# - VITE_API_URL doit être utilisé lors du build frontend, pas forcément en runtime Railway
# - N'utilise pas localhost en production
# - Vérifie que la base Infomaniak autorise les connexions externes

# Analytics (Umami)
# Leave empty to disable analytics
VITE_ANALYTICS_ENDPOINT=https://your-umami-instance.com
VITE_ANALYTICS_WEBSITE_ID=your_website_id

# Environment
NODE_ENV=production
