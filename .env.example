# OAuth Configuration
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com
VITE_APP_ID=your_app_id_here
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your_owner_open_id

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# Database
DATABASE_URL=mysql://user:password@host:port/database

# Notification Service (Forge API)
BUILT_IN_FORGE_API_URL=https://your-forge-api.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here

# Deployment (séparé frontend mutualisé + API Railway)
# VITE_API_URL=https://your-app.railway.app   ← à mettre dans le build frontend (mutualisé)
# ALLOWED_ORIGINS=https://amance.beonweb.cm   ← sur Railway (autorise le domaine du frontend)
# FRONTEND_URL=https://amance.beonweb.cm       ← sur Railway (redirection OAuth)

# Analytics (Umami)
# Leave empty to disable analytics
VITE_ANALYTICS_ENDPOINT=https://your-umami-instance.com
VITE_ANALYTICS_WEBSITE_ID=your_website_id

# Environment
NODE_ENV=production
